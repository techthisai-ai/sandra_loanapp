rules_version = '2';
// Authenticated access only. App uses getFirestore in src/firebase/config.js; enable Storage in
// Console and wire uploads if you add Firebase Storage later.
// Deploy: firebase deploy --only storage
//
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
