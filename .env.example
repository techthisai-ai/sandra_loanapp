# Copy to .env.local only if you need overrides (optional).

# --- Local development (default in .env.development) ---
# npm run dev → live Firebase (VITE_USE_FIREBASE_EMULATORS=false)
# npm run emulators + npm run dev:emulator → isolated emulator data
# VITE_USE_FIREBASE_EMULATORS=false
# VITE_FIREBASE_EMULATOR_HOST=127.0.0.1

# --- Production deploy (default in .env.production) ---
# VITE_USE_FIREBASE_EMULATORS=false

# Firebase web app config (Firebase Console → Project settings → Your apps)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# Rare: allow demo account bootstrap against a non-emulator dev project (not recommended).
# VITE_ALLOW_DEMO_SEED=false
