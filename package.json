  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "vite build --configLoader native",
    "lint": "eslint .",
    "preview": "vite preview --configLoader native",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "android:apk": "npm run build && npx cap sync android && cd android && .\\gradlew.bat assembleDebug",
    "deploy:hosting": "npm run build && npx firebase deploy --only hosting,firestore:rules",
